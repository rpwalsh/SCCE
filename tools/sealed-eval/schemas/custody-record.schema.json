{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CustodyRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sequence",
    "timestamp",
    "actor",
    "event",
    "details",
    "previousHash",
    "recordHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "event": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "previousHash": {
      "type": "string"
    },
    "recordHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
