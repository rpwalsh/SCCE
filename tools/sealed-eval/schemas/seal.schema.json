{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvaluationSeal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "evaluationId",
    "createdAt",
    "hashes",
    "sealHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "evaluationId": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    },
    "metadata": {
      "type": "object"
    },
    "sealHash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
