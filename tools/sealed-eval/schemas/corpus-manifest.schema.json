{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yopp.local/schemas/corpus-manifest.schema.json",
  "title": "CorpusManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "corpusId",
    "documents"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "corpusId": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "documentId",
          "path",
          "sha256",
          "sizeBytes"
        ],
        "properties": {
          "documentId": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          },
          "mediaType": {
            "type": "string"
          },
          "normalization": {
            "type": "string"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
