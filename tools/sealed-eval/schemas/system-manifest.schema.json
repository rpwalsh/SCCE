{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SystemManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "systems"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "systemId",
          "conditionId",
          "mode",
          "command"
        ],
        "properties": {
          "systemId": {
            "type": "string"
          },
          "conditionId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "mode": {
            "enum": [
              "jsonl-stdio",
              "per-question"
            ]
          },
          "command": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "cwd": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1
          },
          "networkPolicy": {
            "type": "string"
          },
          "assistance": {
            "type": "string"
          },
          "brainManifestPath": {
            "type": "string"
          },
          "configurationHash": {
            "type": "string"
          }
        }
      }
    }
  }
}
